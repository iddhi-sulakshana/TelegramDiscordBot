# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Discord webhook URL (Channel Settings -> Integrations -> Webhooks)
DISCORD_WEBHOOK_URL=

# Optional: restrict forwarding to a single chat ID (numeric, negative for groups).
# Leave empty to forward from any chat the bot is added to.
ALLOWED_CHAT_ID=

# Optional: include sender username + chat title in the Discord embed
INCLUDE_METADATA=true

# Optional: priority Telegram user IDs (comma-separated). Messages from these
# users get a red embed. If their message contains "join" or "joi",
# the bot pings @everyone in Discord and attaches MEETING_LINK.
PRIORITY_USER_IDS=

# Meeting link (Zoom/Meet/etc) sent alongside join-trigger messages.
MEETING_LINK=
