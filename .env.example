# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Discord webhook URL (Channel Settings -> Integrations -> Webhooks)
DISCORD_WEBHOOK_URL=

# Optional: restrict forwarding to a single chat ID (numeric, negative for groups).
# Leave empty to forward from any chat the bot is added to.
ALLOWED_CHAT_ID=

# Optional: include sender username + chat title in the Discord embed
INCLUDE_METADATA=true
